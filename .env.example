ANTHROPIC_API_KEY=your-api-key-here
AGENT_ID=
ENVIRONMENT_ID=

# Comma-separated list of valid API keys for the backend REST API
API_KEYS=changeme

# MCP server settings (only needed when running tax_mcp/server.py)
MCP_TRANSPORT=stdio                          # set to "sse" for hosted deployment
MCP_API_KEY=                                 # key clients use to authenticate with the MCP server
TAX_AGENT_API_URL=http://localhost:8000      # backend URL the MCP server calls
